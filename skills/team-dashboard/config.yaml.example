# GitHub Configuration
github:
  token: "${GITHUB_TOKEN}"  # Set via environment variable
  repositories:
    - "openvinotoolkit/openvino"

# JIRA Configuration
jira:
  url: "https://jira.devtools.intel.com"
  email: "${JIRA_EMAIL}"
  api_token: "${JIRA_API_TOKEN}"
  project_keys:
    - "CVS"

# Features Tracking
features:
  # Define features being worked on
  current_sprint:
    - name: "Feature 1"
      lead: "username1"
      status: "In Progress"
    - name: "Feature 2"
      lead: "username2"
      status: "Planning"

# Model Support Tracking
models:
  # Track new models being integrated
  tracking_file: "models.json"

# Customer Engagement
customer_engagement:
  # Configure customer issue tracking
  platforms:
    - type: "github_issues"
      repos: ["org/repo1"]
    - type: "zendesk"
      enabled: false
    - type: "slack"
      enabled: false

# Report Configuration
report:
  output_dir: "reports"
  week_start_day: "monday"  # or "sunday"
  default_format: "html"  # html, markdown, or both
